<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:rive="clr-namespace:Plugin.Maui.Rive;assembly=Plugin.Maui.Rive"
             x:Class="Plugin.Maui.Rive.Sample.StateMachinePage"
             Title="State Machine">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="16">

            <Border StrokeThickness="1"
                    Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#333333}"
                    StrokeShape="RoundRectangle 12"
                    BackgroundColor="{AppThemeBinding Light=#FAFAFA, Dark=#1A1A1A}">
                <rive:RiveAnimationView
                    x:Name="riveView"
                    ResourceName="skills"
                    AutoPlay="True"
                    Fit="Contain"
                    HeightRequest="300"
                    HorizontalOptions="Fill"
                    VerticalOptions="Fill" />
            </Border>

            <!-- Animation selector -->
            <VerticalStackLayout Spacing="8">
                <Label Text="Animation File" FontAttributes="Bold" FontSize="15" />
                <FlexLayout Wrap="Wrap" JustifyContent="Start" AlignItems="Center">
                    <Button Text="Skills" Clicked="OnSkillsClicked" Margin="0,0,8,4" />
                    <Button Text="Off Road" Clicked="OnOffRoadClicked" Margin="0,0,8,4" />
                    <Button Text="Bear" Clicked="OnBearClicked" Margin="0,0,8,4" />
                </FlexLayout>
            </VerticalStackLayout>

            <!-- Trigger Inputs -->
            <VerticalStackLayout Spacing="8">
                <Label Text="Trigger Input" FontAttributes="Bold" FontSize="15" />
                <Grid ColumnDefinitions="*, Auto" ColumnSpacing="8">
                    <Entry x:Name="triggerEntry" Placeholder="Trigger name" />
                    <Button Grid.Column="1" Text="Fire!" Clicked="OnFireTriggerClicked" />
                </Grid>
            </VerticalStackLayout>

            <!-- Bool & Number Inputs -->
            <Grid ColumnDefinitions="*, *" ColumnSpacing="16">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Boolean Input" FontAttributes="Bold" FontSize="15" />
                    <Entry x:Name="boolNameEntry" Placeholder="Input name" />
                    <FlexLayout Wrap="Wrap" JustifyContent="Start" AlignItems="Center">
                        <Button Text="True" Clicked="OnSetBoolTrueClicked" Margin="0,0,8,4" />
                        <Button Text="False" Clicked="OnSetBoolFalseClicked" Margin="0,0,8,4" />
                    </FlexLayout>
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Column="1" Spacing="8">
                    <Label Text="Number Input" FontAttributes="Bold" FontSize="15" />
                    <Entry x:Name="numberNameEntry" Placeholder="Input name" />
                    <Slider x:Name="numberSlider" Minimum="0" Maximum="100" Value="50"
                            ValueChanged="OnNumberSliderChanged" />
                    <Label x:Name="numberValueLabel" Text="Value: 50" HorizontalOptions="Center" FontSize="12"
                           TextColor="{AppThemeBinding Light=#666666, Dark=#999999}" />
                </VerticalStackLayout>
            </Grid>

            <!-- Event Log -->
            <Border StrokeThickness="1"
                    Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#333333}"
                    StrokeShape="RoundRectangle 8"
                    BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#1E1E1E}"
                    Padding="12">
                <VerticalStackLayout Spacing="4">
                    <Label Text="State Machine Events" FontAttributes="Bold" FontSize="13" />
                    <Label x:Name="logLabel" FontSize="11" MaxLines="6" Text="Interact with inputs above..."
                           TextColor="{AppThemeBinding Light=#666666, Dark=#999999}" />
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
