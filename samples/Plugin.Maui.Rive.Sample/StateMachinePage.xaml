<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:rive="clr-namespace:Plugin.Maui.Rive;assembly=Plugin.Maui.Rive"
             x:Class="Plugin.Maui.Rive.Sample.StateMachinePage"
             Title="State Machine">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="16">

            <Border StrokeThickness="1"
                    Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#333333}"
                    StrokeShape="RoundRectangle 12"
                    BackgroundColor="{AppThemeBinding Light=#FAFAFA, Dark=#1A1A1A}">
                <rive:RiveAnimationView
                    x:Name="riveView"
                    ResourceName="skills"
                    AutoPlay="True"
                    Fit="Contain"
                    HeightRequest="300"
                    HorizontalOptions="Fill"
                    VerticalOptions="Fill" />
            </Border>

            <!-- Animation selector -->
            <VerticalStackLayout Spacing="8">
                <Label Text="Animation File" FontAttributes="Bold" FontSize="15" />
                <FlexLayout Wrap="Wrap" JustifyContent="Start" AlignItems="Center">
                    <Button Text="Skills" Clicked="OnAnimationClicked" Margin="0,0,8,4" CommandParameter="skills" />
                    <Button Text="Off Road" Clicked="OnAnimationClicked" Margin="0,0,8,4" CommandParameter="off_road_car" />
                    <Button Text="Bear" Clicked="OnAnimationClicked" Margin="0,0,8,4" CommandParameter="bear" />
                </FlexLayout>
            </VerticalStackLayout>

            <!-- Discovered Inputs (auto-populated) -->
            <Border StrokeThickness="1"
                    Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#333333}"
                    StrokeShape="RoundRectangle 12"
                    BackgroundColor="{AppThemeBinding Light=#FAFAFA, Dark=#1A1A1A}"
                    Padding="16">
                <VerticalStackLayout Spacing="12">
                    <Grid ColumnDefinitions="*, Auto">
                        <Label Text="State Machine Inputs" FontAttributes="Bold" FontSize="16" VerticalOptions="Center" />
                        <Button Grid.Column="1" Text="Refresh" Clicked="OnRefreshInputsClicked"
                                FontSize="12" Padding="12,4" HeightRequest="32" />
                    </Grid>

                    <Label x:Name="noInputsLabel" Text="Tap Refresh to discover inputs..."
                           FontSize="13" IsVisible="True"
                           TextColor="{AppThemeBinding Light=#999999, Dark=#666666}" />

                    <!-- Triggers -->
                    <VerticalStackLayout x:Name="triggersSection" Spacing="6" IsVisible="False">
                        <Label Text="🔫 Triggers" FontAttributes="Bold" FontSize="14"
                               TextColor="{AppThemeBinding Light=#D84315, Dark=#FF8A65}" />
                        <FlexLayout x:Name="triggersContainer" Wrap="Wrap" JustifyContent="Start" AlignItems="Center" />
                    </VerticalStackLayout>

                    <!-- Booleans -->
                    <VerticalStackLayout x:Name="booleansSection" Spacing="6" IsVisible="False">
                        <Label Text="✅ Booleans" FontAttributes="Bold" FontSize="14"
                               TextColor="{AppThemeBinding Light=#1565C0, Dark=#64B5F6}" />
                        <VerticalStackLayout x:Name="booleansContainer" Spacing="4" />
                    </VerticalStackLayout>

                    <!-- Numbers -->
                    <VerticalStackLayout x:Name="numbersSection" Spacing="6" IsVisible="False">
                        <Label Text="🔢 Numbers" FontAttributes="Bold" FontSize="14"
                               TextColor="{AppThemeBinding Light=#2E7D32, Dark=#81C784}" />
                        <VerticalStackLayout x:Name="numbersContainer" Spacing="8" />
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

            <!-- Event Log -->
            <Border StrokeThickness="1"
                    Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#333333}"
                    StrokeShape="RoundRectangle 8"
                    BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#1E1E1E}"
                    Padding="12">
                <VerticalStackLayout Spacing="4">
                    <Label Text="State Machine Events" FontAttributes="Bold" FontSize="13" />
                    <Label x:Name="logLabel" FontSize="11" MaxLines="8" Text="Interact with inputs above..."
                           TextColor="{AppThemeBinding Light=#666666, Dark=#999999}" />
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
