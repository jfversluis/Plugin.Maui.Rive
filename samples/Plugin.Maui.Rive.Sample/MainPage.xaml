<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:rive="clr-namespace:Plugin.Maui.Rive;assembly=Plugin.Maui.Rive"
             x:Class="Plugin.Maui.Rive.Sample.MainPage"
             Title="Playback Control">

    <ScrollView>
        <Grid RowDefinitions="350, Auto, Auto, Auto, Auto, Auto" Padding="16" RowSpacing="12">

            <rive:RiveAnimationView 
                x:Name="riveView"
                ResourceName="vehicles"
                AutoPlay="True"
                Fit="Contain"
                HeightRequest="350"
                HorizontalOptions="Fill"
                VerticalOptions="Fill"
                AutomationId="RiveAnimationView" />

            <!-- Animation Picker -->
            <HorizontalStackLayout Grid.Row="1" HorizontalOptions="Center" Spacing="8">
                <Label Text="Animation:" VerticalOptions="Center" FontAttributes="Bold" />
                <Button Text="Vehicles" Clicked="OnVehiclesClicked" />
                <Button Text="Bear" Clicked="OnBearClicked" />
                <Button Text="Explorer" Clicked="OnExplorerClicked" />
                <Button Text="Tree" Clicked="OnTreeClicked" />
            </HorizontalStackLayout>

            <!-- Playback Controls -->
            <HorizontalStackLayout Grid.Row="2" HorizontalOptions="Center" Spacing="8">
                <Button Text="▶ Play" Clicked="OnPlayClicked" AutomationId="PlayButton" />
                <Button Text="⏸ Pause" Clicked="OnPauseClicked" AutomationId="PauseButton" />
                <Button Text="⏹ Stop" Clicked="OnStopClicked" AutomationId="StopButton" />
                <Button Text="↺ Reset" Clicked="OnResetClicked" AutomationId="ResetButton" />
            </HorizontalStackLayout>

            <!-- Loop Mode -->
            <VerticalStackLayout Grid.Row="3" Spacing="4">
                <Label Text="Loop Mode:" FontAttributes="Bold" />
                <HorizontalStackLayout Spacing="8" HorizontalOptions="Center">
                    <Button Text="OneShot" Clicked="OnLoopOneShotClicked" />
                    <Button Text="Loop" Clicked="OnLoopLoopClicked" />
                    <Button Text="PingPong" Clicked="OnLoopPingPongClicked" />
                    <Button Text="Auto" Clicked="OnLoopAutoClicked" />
                </HorizontalStackLayout>
            </VerticalStackLayout>

            <!-- Direction -->
            <VerticalStackLayout Grid.Row="4" Spacing="4">
                <Label Text="Direction:" FontAttributes="Bold" />
                <HorizontalStackLayout Spacing="8" HorizontalOptions="Center">
                    <Button Text="Forwards" Clicked="OnDirectionForwardsClicked" />
                    <Button Text="Backwards" Clicked="OnDirectionBackwardsClicked" />
                    <Button Text="Auto" Clicked="OnDirectionAutoClicked" />
                </HorizontalStackLayout>
            </VerticalStackLayout>

            <!-- Event Log -->
            <Frame Grid.Row="5" BackgroundColor="{AppThemeBinding Light=#F0F0F0, Dark=#1E1E1E}" Padding="10" CornerRadius="8">
                <VerticalStackLayout>
                    <Label Text="Event Log:" FontAttributes="Bold" />
                    <Label x:Name="eventLogLabel" FontSize="11" MaxLines="8"
                           AutomationId="StatusLabel" Text="Waiting for events..." />
                </VerticalStackLayout>
            </Frame>

        </Grid>
    </ScrollView>
</ContentPage>
