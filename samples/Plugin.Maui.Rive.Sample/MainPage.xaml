<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:rive="clr-namespace:Plugin.Maui.Rive;assembly=Plugin.Maui.Rive"
             x:Class="Plugin.Maui.Rive.Sample.MainPage"
             Title="Playback Control">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="16">

            <Border StrokeThickness="1"
                    Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#333333}"
                    StrokeShape="RoundRectangle 12"
                    BackgroundColor="{AppThemeBinding Light=#FAFAFA, Dark=#1A1A1A}">
                <rive:RiveAnimationView
                    x:Name="riveView"
                    ResourceName="off_road_car"
                    AutoPlay="True"
                    Fit="Contain"
                    HeightRequest="300"
                    HorizontalOptions="Fill"
                    VerticalOptions="Fill"
                    AutomationId="RiveAnimationView" />
            </Border>

            <!-- Animation Picker -->
            <VerticalStackLayout Spacing="8">
                <Label Text="Animation" FontAttributes="Bold" FontSize="15" />
                <FlexLayout Wrap="Wrap" JustifyContent="Start" AlignItems="Center">
                    <Button Text="Off Road" Clicked="OnOffRoadCarClicked" Margin="0,0,8,4" />
                    <Button Text="Bear" Clicked="OnBearClicked" Margin="0,0,8,4" />
                    <Button Text="Explorer" Clicked="OnExplorerClicked" Margin="0,0,8,4" />
                    <Button Text="Tree" Clicked="OnTreeClicked" Margin="0,0,8,4" />
                </FlexLayout>
            </VerticalStackLayout>

            <!-- Playback Controls -->
            <VerticalStackLayout Spacing="8">
                <Label Text="Playback" FontAttributes="Bold" FontSize="15" />
                <FlexLayout Wrap="Wrap" JustifyContent="Start" AlignItems="Center">
                    <Button Text="▶ Play" Clicked="OnPlayClicked" AutomationId="PlayButton" Margin="0,0,8,4" />
                    <Button Text="⏸ Pause" Clicked="OnPauseClicked" AutomationId="PauseButton" Margin="0,0,8,4" />
                    <Button Text="⏹ Stop" Clicked="OnStopClicked" AutomationId="StopButton" Margin="0,0,8,4" />
                    <Button Text="↺ Reset" Clicked="OnResetClicked" AutomationId="ResetButton" Margin="0,0,8,4" />
                </FlexLayout>
            </VerticalStackLayout>

            <!-- Loop Mode -->
            <VerticalStackLayout Spacing="8">
                <Label Text="Loop Mode" FontAttributes="Bold" FontSize="15" />
                <FlexLayout Wrap="Wrap" JustifyContent="Start" AlignItems="Center">
                    <Button Text="OneShot" Clicked="OnLoopOneShotClicked" Margin="0,0,8,4" />
                    <Button Text="Loop" Clicked="OnLoopLoopClicked" Margin="0,0,8,4" />
                    <Button Text="PingPong" Clicked="OnLoopPingPongClicked" Margin="0,0,8,4" />
                    <Button Text="Auto" Clicked="OnLoopAutoClicked" Margin="0,0,8,4" />
                </FlexLayout>
            </VerticalStackLayout>

            <!-- Direction -->
            <VerticalStackLayout Spacing="8">
                <Label Text="Direction" FontAttributes="Bold" FontSize="15" />
                <FlexLayout Wrap="Wrap" JustifyContent="Start" AlignItems="Center">
                    <Button Text="Forwards" Clicked="OnDirectionForwardsClicked" Margin="0,0,8,4" />
                    <Button Text="Backwards" Clicked="OnDirectionBackwardsClicked" Margin="0,0,8,4" />
                    <Button Text="Auto" Clicked="OnDirectionAutoClicked" Margin="0,0,8,4" />
                </FlexLayout>
            </VerticalStackLayout>

            <!-- Event Log -->
            <Border StrokeThickness="1"
                    Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#333333}"
                    StrokeShape="RoundRectangle 8"
                    BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#1E1E1E}"
                    Padding="12">
                <VerticalStackLayout Spacing="4">
                    <Label Text="Event Log" FontAttributes="Bold" FontSize="13" />
                    <Label x:Name="eventLogLabel" FontSize="11" MaxLines="8"
                           AutomationId="StatusLabel" Text="Waiting for events..."
                           TextColor="{AppThemeBinding Light=#666666, Dark=#999999}" />
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
