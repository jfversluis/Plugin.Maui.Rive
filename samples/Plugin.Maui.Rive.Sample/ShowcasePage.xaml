<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:rive="clr-namespace:Plugin.Maui.Rive;assembly=Plugin.Maui.Rive"
             x:Class="Plugin.Maui.Rive.Sample.ShowcasePage"
             Title="Showcase">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="16">

            <Label Text="Animation Showcase"
                   FontSize="22" FontAttributes="Bold"
                   HorizontalOptions="Center" />
            <Label Text="A collection of Rive animations running in .NET MAUI"
                   FontSize="13" HorizontalOptions="Center" Margin="0,0,0,8"
                   TextColor="{AppThemeBinding Light=#888888, Dark=#999999}" />

            <!-- Flux Capacitor -->
            <Border StrokeThickness="1"
                    Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#333333}"
                    StrokeShape="RoundRectangle 16"
                    BackgroundColor="{AppThemeBinding Light=#FAFAFA, Dark=#1A1A1A}">
                <VerticalStackLayout>
                    <rive:RiveAnimationView
                        ResourceName="flux_capacitor"
                        AutoPlay="True" Fit="Contain"
                        HeightRequest="200" HorizontalOptions="Fill" />
                    <VerticalStackLayout Padding="16,8,16,16" Spacing="4">
                        <Label Text="⚡ Flux Capacitor" FontSize="16" FontAttributes="Bold" />
                        <Label Text="Detailed sci-fi mechanical animation"
                               FontSize="12" TextColor="{AppThemeBinding Light=#888, Dark=#999}" />
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

            <!-- Rating -->
            <Border StrokeThickness="1"
                    Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#333333}"
                    StrokeShape="RoundRectangle 16"
                    BackgroundColor="{AppThemeBinding Light=#FAFAFA, Dark=#1A1A1A}">
                <VerticalStackLayout>
                    <rive:RiveAnimationView
                        ResourceName="rating"
                        AutoPlay="True" Fit="Contain"
                        HeightRequest="160" HorizontalOptions="Fill" />
                    <VerticalStackLayout Padding="16,8,16,16" Spacing="4">
                        <Label Text="⭐ Rating" FontSize="16" FontAttributes="Bold" />
                        <Label Text="Interactive star rating with state machine"
                               FontSize="12" TextColor="{AppThemeBinding Light=#888, Dark=#999}" />
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

            <!-- Vehicles -->
            <Border StrokeThickness="1"
                    Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#333333}"
                    StrokeShape="RoundRectangle 16"
                    BackgroundColor="{AppThemeBinding Light=#FAFAFA, Dark=#1A1A1A}">
                <VerticalStackLayout>
                    <rive:RiveAnimationView
                        ResourceName="vehicles"
                        AutoPlay="True" Fit="Contain"
                        HeightRequest="200" HorizontalOptions="Fill" />
                    <VerticalStackLayout Padding="16,8,16,16" Spacing="4">
                        <Label Text="🚗 Vehicles" FontSize="16" FontAttributes="Bold" />
                        <Label Text="Interactive vehicle showcase"
                               FontSize="12" TextColor="{AppThemeBinding Light=#888, Dark=#999}" />
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

            <!-- F-22 -->
            <Border StrokeThickness="1"
                    Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#333333}"
                    StrokeShape="RoundRectangle 16"
                    BackgroundColor="{AppThemeBinding Light=#FAFAFA, Dark=#1A1A1A}">
                <VerticalStackLayout>
                    <rive:RiveAnimationView
                        ResourceName="f22"
                        AutoPlay="True" Fit="Contain"
                        HeightRequest="200" HorizontalOptions="Fill" />
                    <VerticalStackLayout Padding="16,8,16,16" Spacing="4">
                        <Label Text="✈️ F-22 Fighter Jet" FontSize="16" FontAttributes="Bold" />
                        <Label Text="Detailed aircraft animation"
                               FontSize="12" TextColor="{AppThemeBinding Light=#888, Dark=#999}" />
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

            <!-- Skins Demo -->
            <Border StrokeThickness="1"
                    Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#333333}"
                    StrokeShape="RoundRectangle 16"
                    BackgroundColor="{AppThemeBinding Light=#FAFAFA, Dark=#1A1A1A}">
                <VerticalStackLayout>
                    <rive:RiveAnimationView
                        ResourceName="skins_demo"
                        AutoPlay="True" Fit="Contain"
                        HeightRequest="200" HorizontalOptions="Fill" />
                    <VerticalStackLayout Padding="16,8,16,16" Spacing="4">
                        <Label Text="🎨 Skins Demo" FontSize="16" FontAttributes="Bold" />
                        <Label Text="Character skinning and customization"
                               FontSize="12" TextColor="{AppThemeBinding Light=#888, Dark=#999}" />
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

            <!-- Marty -->
            <Border StrokeThickness="1"
                    Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#333333}"
                    StrokeShape="RoundRectangle 16"
                    BackgroundColor="{AppThemeBinding Light=#FAFAFA, Dark=#1A1A1A}">
                <VerticalStackLayout>
                    <rive:RiveAnimationView
                        ResourceName="marty"
                        AutoPlay="True" Fit="Contain"
                        HeightRequest="200" HorizontalOptions="Fill" />
                    <VerticalStackLayout Padding="16,8,16,16" Spacing="4">
                        <Label Text="🤖 Marty" FontSize="16" FontAttributes="Bold" />
                        <Label Text="Animated character with expressions"
                               FontSize="12" TextColor="{AppThemeBinding Light=#888, Dark=#999}" />
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

            <!-- Energy Bar -->
            <Border StrokeThickness="1"
                    Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#333333}"
                    StrokeShape="RoundRectangle 16"
                    BackgroundColor="{AppThemeBinding Light=#FAFAFA, Dark=#1A1A1A}">
                <VerticalStackLayout>
                    <rive:RiveAnimationView
                        ResourceName="energy_bar"
                        AutoPlay="True" Fit="Contain"
                        HeightRequest="160" HorizontalOptions="Fill" />
                    <VerticalStackLayout Padding="16,8,16,16" Spacing="4">
                        <Label Text="🔋 Energy Bar" FontSize="16" FontAttributes="Bold" />
                        <Label Text="Animated progress/energy bar"
                               FontSize="12" TextColor="{AppThemeBinding Light=#888, Dark=#999}" />
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

            <!-- Neostream -->
            <Border StrokeThickness="1"
                    Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#333333}"
                    StrokeShape="RoundRectangle 16"
                    BackgroundColor="{AppThemeBinding Light=#FAFAFA, Dark=#1A1A1A}">
                <VerticalStackLayout>
                    <rive:RiveAnimationView
                        ResourceName="neostream"
                        AutoPlay="True" Fit="Contain"
                        HeightRequest="200" HorizontalOptions="Fill" />
                    <VerticalStackLayout Padding="16,8,16,16" Spacing="4">
                        <Label Text="🌊 Neostream" FontSize="16" FontAttributes="Bold" />
                        <Label Text="Flowing neon stream animation"
                               FontSize="12" TextColor="{AppThemeBinding Light=#888, Dark=#999}" />
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
