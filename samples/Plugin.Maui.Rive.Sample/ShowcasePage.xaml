<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:rive="clr-namespace:Plugin.Maui.Rive;assembly=Plugin.Maui.Rive"
             x:Class="Plugin.Maui.Rive.Sample.ShowcasePage"
             Title="Showcase">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="16">

            <Label Text="Animation Showcase"
                   FontSize="22" FontAttributes="Bold"
                   HorizontalOptions="Center" />
            <Label Text="Some animations respond to touch, others are looping visuals"
                   FontSize="13" HorizontalOptions="Center" Margin="0,0,0,8"
                   TextColor="{AppThemeBinding Light=#888888, Dark=#999999}" />

            <!-- Rating - INTERACTIVE -->
            <Border StrokeThickness="1"
                    Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#333333}"
                    StrokeShape="RoundRectangle 16"
                    BackgroundColor="{AppThemeBinding Light=#FAFAFA, Dark=#1A1A1A}">
                <VerticalStackLayout>
                    <rive:RiveAnimationView
                        ResourceName="rating"
                        AutoPlay="True" Fit="Contain"
                        HeightRequest="160" HorizontalOptions="Fill" />
                    <VerticalStackLayout Padding="16,8,16,16" Spacing="4">
                        <HorizontalStackLayout Spacing="8">
                            <Label Text="⭐ Rating" FontSize="16" FontAttributes="Bold" />
                            <Border StrokeThickness="0" StrokeShape="RoundRectangle 8"
                                    BackgroundColor="#4CAF50" Padding="6,2">
                                <Label Text="👆 Tap to interact" FontSize="10" TextColor="White" />
                            </Border>
                        </HorizontalStackLayout>
                        <Label Text="Tap the stars to set a rating — built-in touch listeners"
                               FontSize="12" TextColor="{AppThemeBinding Light=#888, Dark=#999}" />
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

            <!-- Skins Demo - INTERACTIVE -->
            <Border StrokeThickness="1"
                    Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#333333}"
                    StrokeShape="RoundRectangle 16"
                    BackgroundColor="{AppThemeBinding Light=#FAFAFA, Dark=#1A1A1A}">
                <VerticalStackLayout>
                    <rive:RiveAnimationView
                        ResourceName="skins_demo"
                        AutoPlay="True" Fit="Contain"
                        HeightRequest="200" HorizontalOptions="Fill" />
                    <VerticalStackLayout Padding="16,8,16,16" Spacing="4">
                        <HorizontalStackLayout Spacing="8">
                            <Label Text="🎨 Skins Demo" FontSize="16" FontAttributes="Bold" />
                            <Border StrokeThickness="0" StrokeShape="RoundRectangle 8"
                                    BackgroundColor="#4CAF50" Padding="6,2">
                                <Label Text="👆 Tap to interact" FontSize="10" TextColor="White" />
                            </Border>
                        </HorizontalStackLayout>
                        <Label Text="Tap to cycle through character skins"
                               FontSize="12" TextColor="{AppThemeBinding Light=#888, Dark=#999}" />
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

            <!-- Off Road Car - LOOPING -->
            <Border StrokeThickness="1"
                    Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#333333}"
                    StrokeShape="RoundRectangle 16"
                    BackgroundColor="{AppThemeBinding Light=#FAFAFA, Dark=#1A1A1A}">
                <VerticalStackLayout>
                    <rive:RiveAnimationView
                        ResourceName="off_road_car"
                        AutoPlay="True" Fit="Contain"
                        HeightRequest="200" HorizontalOptions="Fill" />
                    <VerticalStackLayout Padding="16,8,16,16" Spacing="4">
                        <HorizontalStackLayout Spacing="8">
                            <Label Text="🚗 Off Road Car" FontSize="16" FontAttributes="Bold" />
                            <Border StrokeThickness="0" StrokeShape="RoundRectangle 8"
                                    BackgroundColor="{AppThemeBinding Light=#9E9E9E, Dark=#666}" Padding="6,2">
                                <Label Text="🔁 Looping" FontSize="10" TextColor="White" />
                            </Border>
                        </HorizontalStackLayout>
                        <Label Text="Bouncy off-road driving animation — auto-playing loop"
                               FontSize="12" TextColor="{AppThemeBinding Light=#888, Dark=#999}" />
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

            <!-- Flux Capacitor - LOOPING -->
            <Border StrokeThickness="1"
                    Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#333333}"
                    StrokeShape="RoundRectangle 16"
                    BackgroundColor="{AppThemeBinding Light=#FAFAFA, Dark=#1A1A1A}">
                <VerticalStackLayout>
                    <rive:RiveAnimationView
                        ResourceName="flux_capacitor"
                        AutoPlay="True" Fit="Contain"
                        HeightRequest="200" HorizontalOptions="Fill" />
                    <VerticalStackLayout Padding="16,8,16,16" Spacing="4">
                        <HorizontalStackLayout Spacing="8">
                            <Label Text="⚡ Flux Capacitor" FontSize="16" FontAttributes="Bold" />
                            <Border StrokeThickness="0" StrokeShape="RoundRectangle 8"
                                    BackgroundColor="{AppThemeBinding Light=#9E9E9E, Dark=#666}" Padding="6,2">
                                <Label Text="🔁 Looping" FontSize="10" TextColor="White" />
                            </Border>
                        </HorizontalStackLayout>
                        <Label Text="Detailed sci-fi mechanical animation — auto-playing loop"
                               FontSize="12" TextColor="{AppThemeBinding Light=#888, Dark=#999}" />
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

            <!-- F-22 - LOOPING -->
            <Border StrokeThickness="1"
                    Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#333333}"
                    StrokeShape="RoundRectangle 16"
                    BackgroundColor="{AppThemeBinding Light=#FAFAFA, Dark=#1A1A1A}">
                <VerticalStackLayout>
                    <rive:RiveAnimationView
                        ResourceName="f22"
                        AutoPlay="True" Fit="Contain"
                        HeightRequest="200" HorizontalOptions="Fill" />
                    <VerticalStackLayout Padding="16,8,16,16" Spacing="4">
                        <HorizontalStackLayout Spacing="8">
                            <Label Text="✈️ F-22 Fighter Jet" FontSize="16" FontAttributes="Bold" />
                            <Border StrokeThickness="0" StrokeShape="RoundRectangle 8"
                                    BackgroundColor="{AppThemeBinding Light=#9E9E9E, Dark=#666}" Padding="6,2">
                                <Label Text="🔁 Looping" FontSize="10" TextColor="White" />
                            </Border>
                        </HorizontalStackLayout>
                        <Label Text="Aircraft flyby animation — auto-playing loop"
                               FontSize="12" TextColor="{AppThemeBinding Light=#888, Dark=#999}" />
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

            <!-- Marty - LOOPING -->
            <Border StrokeThickness="1"
                    Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#333333}"
                    StrokeShape="RoundRectangle 16"
                    BackgroundColor="{AppThemeBinding Light=#FAFAFA, Dark=#1A1A1A}">
                <VerticalStackLayout>
                    <rive:RiveAnimationView
                        ResourceName="marty"
                        AutoPlay="True" Fit="Contain"
                        HeightRequest="200" HorizontalOptions="Fill" />
                    <VerticalStackLayout Padding="16,8,16,16" Spacing="4">
                        <HorizontalStackLayout Spacing="8">
                            <Label Text="🤖 Marty" FontSize="16" FontAttributes="Bold" />
                            <Border StrokeThickness="0" StrokeShape="RoundRectangle 8"
                                    BackgroundColor="{AppThemeBinding Light=#9E9E9E, Dark=#666}" Padding="6,2">
                                <Label Text="🔁 Looping" FontSize="10" TextColor="White" />
                            </Border>
                        </HorizontalStackLayout>
                        <Label Text="Animated character with expressions — auto-playing loop"
                               FontSize="12" TextColor="{AppThemeBinding Light=#888, Dark=#999}" />
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

            <!-- Neostream - LOOPING -->
            <Border StrokeThickness="1"
                    Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#333333}"
                    StrokeShape="RoundRectangle 16"
                    BackgroundColor="{AppThemeBinding Light=#FAFAFA, Dark=#1A1A1A}">
                <VerticalStackLayout>
                    <rive:RiveAnimationView
                        ResourceName="neostream"
                        AutoPlay="True" Fit="Contain"
                        HeightRequest="200" HorizontalOptions="Fill" />
                    <VerticalStackLayout Padding="16,8,16,16" Spacing="4">
                        <HorizontalStackLayout Spacing="8">
                            <Label Text="🌊 Neostream" FontSize="16" FontAttributes="Bold" />
                            <Border StrokeThickness="0" StrokeShape="RoundRectangle 8"
                                    BackgroundColor="{AppThemeBinding Light=#9E9E9E, Dark=#666}" Padding="6,2">
                                <Label Text="🔁 Looping" FontSize="10" TextColor="White" />
                            </Border>
                        </HorizontalStackLayout>
                        <Label Text="Flowing neon stream — auto-playing loop"
                               FontSize="12" TextColor="{AppThemeBinding Light=#888, Dark=#999}" />
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
