<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:rive="clr-namespace:Plugin.Maui.Rive;assembly=Plugin.Maui.Rive"
             x:Class="Plugin.Maui.Rive.Sample.ByteLoadingPage"
             Title="Byte Loading">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="16">

            <Border StrokeThickness="1"
                    Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#333333}"
                    StrokeShape="RoundRectangle 12"
                    BackgroundColor="{AppThemeBinding Light=#FAFAFA, Dark=#1A1A1A}">
                <rive:RiveAnimationView
                    x:Name="riveView"
                    AutoPlay="True"
                    Fit="Contain"
                    HeightRequest="280"
                    HorizontalOptions="Fill"
                    VerticalOptions="Fill" />
            </Border>

            <!-- Load from bundled resource -->
            <VerticalStackLayout Spacing="8">
                <Label Text="From Bundled Resource" FontAttributes="Bold" FontSize="15" />
                <Label Text="Load a .riv file bundled as a MauiAsset in the app." FontSize="12"
                       TextColor="{AppThemeBinding Light=#666666, Dark=#999999}" />
                <FlexLayout Wrap="Wrap" JustifyContent="Start" AlignItems="Center">
                    <Button Text="off_road_car" Clicked="OnLoadResourceClicked" CommandParameter="off_road_car" Margin="0,0,8,4" />
                    <Button Text="bear" Clicked="OnLoadResourceClicked" CommandParameter="bear" Margin="0,0,8,4" />
                    <Button Text="explorer" Clicked="OnLoadResourceClicked" CommandParameter="explorer" Margin="0,0,8,4" />
                </FlexLayout>
            </VerticalStackLayout>

            <!-- Load from URL -->
            <VerticalStackLayout Spacing="8">
                <Label Text="From URL" FontAttributes="Bold" FontSize="15" />
                <Label Text="Download a .riv file from a remote URL at runtime." FontSize="12"
                       TextColor="{AppThemeBinding Light=#666666, Dark=#999999}" />
                <Grid ColumnDefinitions="*, Auto" ColumnSpacing="8">
                    <Entry x:Name="urlEntry" Placeholder="https://cdn.rive.app/animations/..."
                           Text="https://cdn.rive.app/animations/vehicles.riv" FontSize="12" />
                    <Button Grid.Column="1" Text="Load" Clicked="OnLoadUrlClicked" />
                </Grid>
            </VerticalStackLayout>

            <!-- Status -->
            <Border StrokeThickness="1"
                    Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#333333}"
                    StrokeShape="RoundRectangle 8"
                    BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#1E1E1E}"
                    Padding="12">
                <VerticalStackLayout Spacing="4">
                    <Label Text="Load Status" FontAttributes="Bold" FontSize="13" />
                    <Label x:Name="statusLabel" FontSize="12" Text="No animation loaded yet."
                           TextColor="{AppThemeBinding Light=#666666, Dark=#999999}" />
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
