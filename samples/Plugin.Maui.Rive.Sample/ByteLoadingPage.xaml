<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:rive="clr-namespace:Plugin.Maui.Rive;assembly=Plugin.Maui.Rive"
             x:Class="Plugin.Maui.Rive.Sample.ByteLoadingPage"
             Title="Byte Loading">

    <ScrollView>
        <Grid RowDefinitions="300, Auto, Auto, Auto, Auto" Padding="16" RowSpacing="12">

            <rive:RiveAnimationView
                x:Name="riveView"
                AutoPlay="True"
                Fit="Contain"
                HeightRequest="300"
                HorizontalOptions="Fill"
                VerticalOptions="Fill" />

            <Label Grid.Row="1" Text="Load animations from different sources:" FontAttributes="Bold" />

            <!-- Load from bundled resource -->
            <VerticalStackLayout Grid.Row="2" Spacing="8">
                <Label Text="From Bundled Resource (ResourceName):" FontSize="13" />
                <HorizontalStackLayout Spacing="8" HorizontalOptions="Center">
                    <Button Text="vehicles" Clicked="OnLoadResourceClicked" CommandParameter="vehicles" />
                    <Button Text="bear" Clicked="OnLoadResourceClicked" CommandParameter="bear" />
                    <Button Text="explorer" Clicked="OnLoadResourceClicked" CommandParameter="explorer" />
                </HorizontalStackLayout>
            </VerticalStackLayout>

            <!-- Load from URL -->
            <VerticalStackLayout Grid.Row="3" Spacing="8">
                <Label Text="From URL:" FontSize="13" />
                <Grid ColumnDefinitions="*, Auto" ColumnSpacing="8">
                    <Entry x:Name="urlEntry" Placeholder="https://cdn.rive.app/animations/..."
                           Text="https://cdn.rive.app/animations/vehicles.riv" FontSize="12" />
                    <Button Grid.Column="1" Text="Load URL" Clicked="OnLoadUrlClicked" />
                </Grid>
            </VerticalStackLayout>

            <!-- Status -->
            <Frame Grid.Row="4" BackgroundColor="{AppThemeBinding Light=#F0F0F0, Dark=#1E1E1E}" Padding="10" CornerRadius="8">
                <VerticalStackLayout Spacing="4">
                    <Label Text="Load Status:" FontAttributes="Bold" />
                    <Label x:Name="statusLabel" FontSize="11" Text="No animation loaded yet." />
                </VerticalStackLayout>
            </Frame>

        </Grid>
    </ScrollView>
</ContentPage>
