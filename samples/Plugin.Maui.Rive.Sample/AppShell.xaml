<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Plugin.Maui.Rive.Sample.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:pages="clr-namespace:Plugin.Maui.Rive.Sample"
    Title="Rive for .NET MAUI">

    <TabBar>
        <ShellContent Title="Playback" Icon="{OnPlatform iOS='play.circle', Default=''}"
            ContentTemplate="{DataTemplate pages:MainPage}" />
        <ShellContent Title="State Machine" Icon="{OnPlatform iOS='gearshape', Default=''}"
            ContentTemplate="{DataTemplate pages:StateMachinePage}" />
        <ShellContent Title="Fit &amp; Align" Icon="{OnPlatform iOS='aspectratio', Default=''}"
            ContentTemplate="{DataTemplate pages:FitAlignmentPage}" />
        <ShellContent Title="Introspection" Icon="{OnPlatform iOS='info.circle', Default=''}"
            ContentTemplate="{DataTemplate pages:IntrospectionPage}" />
        <ShellContent Title="Byte Loading" Icon="{OnPlatform iOS='doc', Default=''}"
            ContentTemplate="{DataTemplate pages:ByteLoadingPage}" />
    </TabBar>

</Shell>
