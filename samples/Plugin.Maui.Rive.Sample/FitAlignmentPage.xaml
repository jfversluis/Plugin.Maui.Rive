<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:rive="clr-namespace:Plugin.Maui.Rive;assembly=Plugin.Maui.Rive"
             x:Class="Plugin.Maui.Rive.Sample.FitAlignmentPage"
             Title="Fit &amp; Alignment">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="16">

            <Border StrokeThickness="2"
                    Stroke="{AppThemeBinding Light=#CCCCCC, Dark=#444444}"
                    StrokeShape="RoundRectangle 12"
                    StrokeDashArray="6,3">
                <rive:RiveAnimationView
                    x:Name="riveView"
                    ResourceName="off_road_car"
                    AutoPlay="True"
                    Fit="Contain"
                    RiveAlignment="Center"
                    HeightRequest="260"
                    HorizontalOptions="Fill"
                    VerticalOptions="Fill" />
            </Border>

            <!-- Current settings display -->
            <Border StrokeThickness="1"
                    Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#333333}"
                    StrokeShape="RoundRectangle 8"
                    BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#1E1E1E}"
                    Padding="12">
                <Label x:Name="settingsLabel" FontSize="14"
                       Text="Fit: Contain  •  Alignment: Center" HorizontalOptions="Center"
                       FontAttributes="Bold" />
            </Border>

            <!-- Fit Mode -->
            <VerticalStackLayout Spacing="8">
                <Label Text="Fit Mode" FontAttributes="Bold" FontSize="15" />
                <FlexLayout Wrap="Wrap" JustifyContent="Start" AlignItems="Center">
                    <Button Text="Fill" Clicked="OnFitClicked" Margin="0,0,8,4" />
                    <Button Text="Contain" Clicked="OnFitClicked" Margin="0,0,8,4" />
                    <Button Text="Cover" Clicked="OnFitClicked" Margin="0,0,8,4" />
                    <Button Text="FitWidth" Clicked="OnFitClicked" Margin="0,0,8,4" />
                    <Button Text="FitHeight" Clicked="OnFitClicked" Margin="0,0,8,4" />
                    <Button Text="ScaleDown" Clicked="OnFitClicked" Margin="0,0,8,4" />
                    <Button Text="NoFit" Clicked="OnFitClicked" Margin="0,0,8,4" />
                    <Button Text="Layout" Clicked="OnFitClicked" Margin="0,0,8,4" />
                </FlexLayout>
            </VerticalStackLayout>

            <!-- Alignment -->
            <VerticalStackLayout Spacing="8">
                <Label Text="Alignment" FontAttributes="Bold" FontSize="15" />
                <Grid ColumnDefinitions="*,*,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="6" RowSpacing="6"
                      HorizontalOptions="Center" WidthRequest="280">
                    <Button Text="↖ TL" Grid.Row="0" Grid.Column="0" Clicked="OnAlignClicked" CommandParameter="TopLeft" />
                    <Button Text="↑ TC" Grid.Row="0" Grid.Column="1" Clicked="OnAlignClicked" CommandParameter="TopCenter" />
                    <Button Text="↗ TR" Grid.Row="0" Grid.Column="2" Clicked="OnAlignClicked" CommandParameter="TopRight" />
                    <Button Text="← CL" Grid.Row="1" Grid.Column="0" Clicked="OnAlignClicked" CommandParameter="CenterLeft" />
                    <Button Text="● C" Grid.Row="1" Grid.Column="1" Clicked="OnAlignClicked" CommandParameter="Center" />
                    <Button Text="→ CR" Grid.Row="1" Grid.Column="2" Clicked="OnAlignClicked" CommandParameter="CenterRight" />
                    <Button Text="↙ BL" Grid.Row="2" Grid.Column="0" Clicked="OnAlignClicked" CommandParameter="BottomLeft" />
                    <Button Text="↓ BC" Grid.Row="2" Grid.Column="1" Clicked="OnAlignClicked" CommandParameter="BottomCenter" />
                    <Button Text="↘ BR" Grid.Row="2" Grid.Column="2" Clicked="OnAlignClicked" CommandParameter="BottomRight" />
                </Grid>
            </VerticalStackLayout>

            <!-- Layout Scale Factor -->
            <VerticalStackLayout Spacing="8">
                <Label Text="Layout Scale Factor (Fit=Layout)" FontAttributes="Bold" FontSize="15" />
                <Grid ColumnDefinitions="*, Auto" ColumnSpacing="12">
                    <Slider x:Name="scaleSlider" Minimum="0.5" Maximum="3.0" Value="1.0"
                            ValueChanged="OnScaleChanged" />
                    <Label x:Name="scaleLabel" Grid.Column="1" Text="1.0x" VerticalOptions="Center"
                           FontAttributes="Bold" WidthRequest="40" />
                </Grid>
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
