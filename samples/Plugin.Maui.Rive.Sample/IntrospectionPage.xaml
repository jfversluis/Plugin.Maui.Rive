<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:rive="clr-namespace:Plugin.Maui.Rive;assembly=Plugin.Maui.Rive"
             x:Class="Plugin.Maui.Rive.Sample.IntrospectionPage"
             Title="Introspection">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="16">

            <Border StrokeThickness="1"
                    Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#333333}"
                    StrokeShape="RoundRectangle 12"
                    BackgroundColor="{AppThemeBinding Light=#FAFAFA, Dark=#1A1A1A}">
                <rive:RiveAnimationView
                    x:Name="riveView"
                    ResourceName="vehicles"
                    AutoPlay="True"
                    Fit="Contain"
                    HeightRequest="220"
                    HorizontalOptions="Fill"
                    VerticalOptions="Fill" />
            </Border>

            <!-- Animation selector -->
            <VerticalStackLayout Spacing="8">
                <Label Text="Animation File" FontAttributes="Bold" FontSize="15" />
                <FlexLayout Wrap="Wrap" JustifyContent="Start" AlignItems="Center">
                    <Button Text="Vehicles" Clicked="OnVehiclesClicked" Margin="0,0,8,4" />
                    <Button Text="Skills" Clicked="OnSkillsClicked" Margin="0,0,8,4" />
                    <Button Text="Bear" Clicked="OnBearClicked" Margin="0,0,8,4" />
                    <Button Text="Explorer" Clicked="OnExplorerClicked" Margin="0,0,8,4" />
                </FlexLayout>
            </VerticalStackLayout>

            <!-- Query Buttons -->
            <FlexLayout Wrap="Wrap" JustifyContent="Start" AlignItems="Center">
                <Button Text="Query All" Clicked="OnQueryAllClicked" FontAttributes="Bold" Margin="0,0,8,4" />
                <Button Text="IsPlaying?" Clicked="OnIsPlayingClicked" Margin="0,0,8,4" />
            </FlexLayout>

            <!-- Results -->
            <Border StrokeThickness="1"
                    Stroke="{AppThemeBinding Light=#E0E0E0, Dark=#333333}"
                    StrokeShape="RoundRectangle 8"
                    BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#1E1E1E}"
                    Padding="16">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Introspection Results" FontAttributes="Bold" FontSize="15" />

                    <VerticalStackLayout Spacing="2">
                        <Label Text="Artboard Names" FontAttributes="Bold" FontSize="13" />
                        <Label x:Name="artboardNamesLabel" FontSize="12" Text="(tap Query All)"
                               TextColor="{AppThemeBinding Light=#666666, Dark=#999999}" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="2">
                        <Label Text="Animation Names" FontAttributes="Bold" FontSize="13" />
                        <Label x:Name="animationNamesLabel" FontSize="12" Text="—"
                               TextColor="{AppThemeBinding Light=#666666, Dark=#999999}" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="2">
                        <Label Text="State Machine Names" FontAttributes="Bold" FontSize="13" />
                        <Label x:Name="stateMachineNamesLabel" FontSize="12" Text="—"
                               TextColor="{AppThemeBinding Light=#666666, Dark=#999999}" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="2">
                        <Label Text="Input Names" FontAttributes="Bold" FontSize="13" />
                        <Label x:Name="inputNamesLabel" FontSize="12" Text="—"
                               TextColor="{AppThemeBinding Light=#666666, Dark=#999999}" />
                    </VerticalStackLayout>

                    <Label x:Name="isPlayingLabel" FontSize="13" Text=""
                           TextColor="{AppThemeBinding Light=#333333, Dark=#CCCCCC}" />
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
